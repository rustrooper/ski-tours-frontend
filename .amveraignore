# Зависимости (их установит pnpm/npm на сервере)
node_modules/
.pnpm-store/
.pnpm/
.pnp
.pnp.*
.yarn/

# Локальная сборка и кэши Next.js (пересобираются на сервере)
.next/
out/
build/
coverage/

# TypeScript кэш и автогенерация
*.tsbuildinfo
tsconfig.tsbuildinfo
next-env.d.ts

# Системные/служебные папки разработки
.git/
.gitignore
.gitattributes
.husky/
.claude/
.agents/
.idea/
.vscode/
.vercel/

# Локальные конфиги и документация (не нужны для сборки)
